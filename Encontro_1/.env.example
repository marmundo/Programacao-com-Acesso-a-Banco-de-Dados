# Configuração do Banco de Dados

# Para Clever Cloud (RECOMENDADO - 100% GRATUITO):
# Obtenha as credenciais em: https://www.clever-cloud.com
# Veja o guia completo em: CLEVERCLOUD.md
DB_HOST=seu_host.mysql.services.clever-cloud.com
DB_PORT=3306
DB_USER=seu_usuario_clevercloud
DB_PASS=sua_senha_clevercloud
DB_NAME=seu_database_clevercloud
DB_SSL=false

# Para MySQL Local:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=sua_senha_aqui
# DB_NAME=escola
# DB_SSL=false

# Para PlanetScale (não tem mais tier gratuito):
# DB_HOST=aws.connect.psdb.cloud
# DB_PORT=3306
# DB_USER=seu_username_planetscale
# DB_PASS=sua_password_planetscale
# DB_NAME=escola
# DB_SSL=true

# Porta da aplicação
PORT=3000
